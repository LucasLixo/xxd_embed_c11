/* Embed content into hex array for in-memory caching */
#include <stddef.h>
#include <stdint.h>
#include "xxd.h"

/* xxd generates unsigned char data; cast to signed char for the API. */
static const uint8_t hex_content_@FILE_KEY_HASH@[] = { @CONTENT_HEX@, 0 };


#ifdef _MSC_VER
#  pragma section(".CRT$XCU", read)
static void xxd_register_@FILE_KEY_HASH@(void);
__declspec(allocate(".CRT$XCU")) void (*xxd_init_@FILE_KEY_HASH@)(void) = xxd_register_@FILE_KEY_HASH@;
static void xxd_register_@FILE_KEY_HASH@(void)
#else
__attribute__((constructor)) static void xxd_register_@FILE_KEY_HASH@(void)
#endif
{
  xxd_add("@FILE_KEY@", (const char*)hex_content_@FILE_KEY_HASH@, sizeof(hex_content_@FILE_KEY_HASH@) - 1, "@FILE_MIME@");
}
